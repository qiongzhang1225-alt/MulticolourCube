  m_text: "<size=26><b>\u25C6 \u6E38\u620F\u4ECB\u7ECD</b></size>\n\u4F60\u63A7\u5236\u4E00\u4E2A\u6709\u56DB\u79CD\u989C\u8272\u9762\u7684\u65B9\u5757\uFF0C\u5728\u5145\u6EE1\u8C1C\u9898\u7684\u5173\u5361\u4E2D\n\u7FFB\u6EDA\u524D\u8FDB\uFF0C\u5229\u7528\u4E0D\u540C\u989C\u8272\u6FC0\u6D3B\u673A\u5173\uFF0C\u6536\u96C6\u661F\u661F\u5230\u8FBE\u7EC8\u70B9\u3002\n\n<size=26><b>\u25C6
    \u64CD\u4F5C\u8BF4\u660E</b></size>\n<b>\u79FB\u52A8</b>      A / D  \u6216 
    \u2190 \u2192\n<b>\u8DF3\u8DC3</b>      W  \u6216  \u7A7A\u683C\n<b>\u7FFB\u6EDA</b>     
    \u9F20\u6807\u5DE6\u952E\u70B9\u51FB\n           \u70B9\u51FB\u65B9\u5757\u5DE6\u4FA7
    \u2192 \u5411\u5DE6\u7FFB\u6EDA\n           \u70B9\u51FB\u65B9\u5757\u53F3\u4FA7
    \u2192 \u5411\u53F3\u7FFB\u6EDA\n<b>\u6682\u505C</b>      Esc\n\n<size=26><b>\u25C6
    \u989C\u8272\u673A\u5236</b></size>\n\u65B9\u5757\u6709\u56DB\u4E2A\u989C\u8272\u9762\uFF1A\n 
    <color=#FFE900>\u25A0</color> \u9EC4\u8272 (\u9876\u9762)    <color=#00E5EF>\u25A0</color>
    \u84DD\u8272 (\u5E95\u9762)\n  <color=#FF3030>\u25A0</color> \u7EA2\u8272 (\u5DE6\u9762)   
    <color=#00FF30>\u25A0</color> \u7EFF\u8272 (\u53F3\u9762)\n\n\u63A5\u89E6\u300C\u53D8\u8272\u65B9\u5757\u300D\u65F6\uFF0C\u63A5\u89E6\u9762\u7684\u989C\u8272\u4F1A\u4F20\u9012\u7ED9\u5B83\u3002\n\u8BA9\u6240\u6709\u53D8\u8272\u65B9\u5757\u53D8\u6210\u6307\u5B9A\u989C\u8272\uFF0C\u5373\u53EF\u89E6\u53D1\u673A\u5173\u3002\n\n<size=26><b>\u25C6
    \u6536\u96C6\u7269</b></size>\n<color=#FFE900>\u2605 \u661F\u661F</color>  \u6BCF\u5173\u6700\u591A
    3 \u9897\uFF0C\u89E3\u9501\u65B0\u7AE0\u8282\u7684\u5173\u952E\n<color=#FFD700>\u25CF
    \u91D1\u5E01</color>  \u6563\u5E03\u5728\u5173\u5361\u89D2\u843D\uFF0C\u8003\u9A8C\u63A2\u7D22\u6B32\n\n<size=26><b>\u25C6
    \u5173\u5361\u7CFB\u7EDF</b></size>\n\u2022 \u6BCF\u5173\u83B7\u5F97 \u22652
    \u9897\u661F\u661F\uFF0C\u53EF\u89E3\u9501\u672C\u7AE0\u4E0B\u4E00\u5173\n\u2022
    \u7D2F\u8BA1\u8DB3\u591F\u661F\u661F\uFF0C\u53EF\u89E3\u9501\u65B0\u7AE0\u8282\n\u2022
